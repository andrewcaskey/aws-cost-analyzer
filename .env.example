# .env.example
# Copy this to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# Load before running scripts: source .env
# Or set per-command:          AWS_PROFILE=my-profile make cost

# Your AWS CLI named profile (configured in ~/.aws/config)
AWS_PROFILE=your-profile-name

# AWS region for Terraform and CLI commands
AWS_REGION=us-east-1
